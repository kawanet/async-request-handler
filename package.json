{
  "name": "async-request-handler",
  "description": "Safe async RequestHandler to catch Promise rejection",
  "version": "1.1.1",
  "author": "Yusuke Kawasaki <u-suke@kawa.net>",
  "bugs": {
    "url": "https://github.com/kawanet/async-request-handler/issues"
  },
  "contributors": [
    "Yusuke Kawasaki <u-suke@kawa.net>"
  ],
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-sucrase": "^5.1.0",
    "@types/express": "^4.17.21",
    "@types/express4": "npm:@types/express@^4",
    "@types/express5": "npm:@types/express@^5",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.2.0",
    "express4": "npm:express@^4",
    "express5": "npm:express@^5",
    "rollup": "^4.60.3",
    "supertest": "^7.2.2",
    "ts-refine": "^0.6.0",
    "typescript": "^5.9.3"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22",
      "onFail": "warn"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./types/async-request-handler.d.ts",
      "require": "./dist/async-request-handler.cjs",
      "import": "./dist/async-request-handler.mjs"
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/async-request-handler.cjs",
    "dist/async-request-handler.mjs",
    "lib/*.ts",
    "types/*.d.ts"
  ],
  "homepage": "https://github.com/kawanet/async-request-handler#readme",
  "keywords": [
    "async",
    "expressjs",
    "middleware",
    "promise"
  ],
  "license": "MIT",
  "main": "./dist/async-request-handler.cjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kawanet/async-request-handler.git"
  },
  "scripts": {
    "build": "make -C builder",
    "fixpack": "fixpack",
    "prepack": "make -C builder is-buildable",
    "prepare": "make -C builder is-not-buildable 2> /dev/null || make -C builder clean all test",
    "test": "make -C builder test",
    "ts-refine": "./node_modules/.bin/ts-refine format && ./node_modules/.bin/ts-refine imports"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./types/async-request-handler.d.ts"
}
